# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
#   Windows (PowerShell):  Copy-Item .env.example .env
#   macOS / Linux:         cp .env.example .env
# NEVER commit your real .env file (it is already in .gitignore).
# ---------------------------------------------------------------------------

# Which backend to use for the LLM + embeddings: "gemini" (default) or "openai".
LLM_PROVIDER=gemini

# --- Google Gemini (default provider) ---
# Get a free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# --- OpenAI (only needed if LLM_PROVIDER=openai) ---
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# --- Optional overrides (sensible defaults are used if these are omitted) ---
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=models/gemini-embedding-001
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# CHROMA_DIR=chroma_db
